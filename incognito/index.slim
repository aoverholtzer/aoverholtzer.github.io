	javascript type="application/ld+json":
		{
		  "@context": "https://schema.org",
		  "@type": "FAQPage",
		  "mainEntity": [
			{
			  "@type": "Question",
			  "name": "What is Incognito — Private Browser?",
			  "acceptedAnswer": {
				"@type": "Answer",
				"text": "Incognito is a private browser for iPhone and iPad that you can open from inside any app. It lets you browse the web privately without leaving a trace — all cookies and browsing data are discarded after each session. It's a one-time $0.99 purchase with no ads, no subscription, and no trackers."
			  }
			},
			{
			  "@type": "Question",
			  "name": "Why would I need Incognito if Safari already has Private Browsing?",
			  "acceptedAnswer": {
				"@type": "Answer",
				"text": "Many apps use their own built-in browsers to track everything you read and tap — even when you think you're just viewing a link. Incognito lets you open any link in a clean, private browser directly from the share sheet of any app, bypassing in-app browsers entirely. You never have to switch to Safari first."
			  }
			},
			{
			  "@type": "Question",
			  "name": "What's the difference between Incognito and Safari Private Browsing?",
			  "acceptedAnswer": {
				"@type": "Answer",
				"text": "Safari Private Browsing is great, but it only works inside Safari. The problem is that most apps — social media, news, email, and others — open links in their own built-in browser, not Safari, so your browsing never reaches Safari's private mode at all. Incognito works from the iOS share sheet, so you can open any link privately from any app in one tap, without ever leaving that app to switch to Safari."
			  }
			},
			{
			  "@type": "Question",
			  "name": "How does Incognito work?",
			  "acceptedAnswer": {
				"@type": "Answer",
				"text": "Tap the share button in any app and select Incognito from the share sheet to instantly open the link in a private browser. All browsing happens in private mode by default: no history is saved, all cookies and web data are discarded when you close the session, and nothing is synced or backed up."
			  }
			},
			{
			  "@type": "Question",
			  "name": "How much does Incognito cost?",
			  "acceptedAnswer": {
				"@type": "Answer",
				"text": "Incognito is $0.99 — a one-time purchase. There is no subscription, no ads, and no in-app purchases. Pay once and browse privately forever."
			  }
			},
			{
			  "@type": "Question",
			  "name": "What devices does Incognito support?",
			  "acceptedAnswer": {
				"@type": "Answer",
				"text": "Incognito runs on iPhone and iPad (iOS 18.5+ and iPadOS 18.5+)."
			  }
			},
			{
			  "@type": "Question",
			  "name": "Can Incognito help bypass paywalls?",
			  "acceptedAnswer": {
				"@type": "Answer",
				"text": "Often, yes. Many paywalls rely on cookies to count how many articles you've read. Because Incognito discards all cookies after each session, reopening a page in Incognito will frequently reset that count and let you read freely."
			  }
			},
			{
			  "@type": "Question",
			  "name": "Does Incognito block trackers and ads?",
			  "acceptedAnswer": {
				"@type": "Answer",
				"text": "Yes and no. Incognito never saves cookies between sessions, so trackers and ads cannot track you between sessions. However, Incognito is not blocking any tracker or ads."
			  }
			},
			{
			  "@type": "Question",
			  "name": "Can I search the web from any app using Incognito?",
				"acceptedAnswer": {
				  "@type": "Answer",
				  "text": "Yes — this is one of Incognito's most useful features. Select any text in any app, tap Share, and choose 'Search in Incognito' to instantly search for that text privately without switching apps or copying anything. You can also type directly in Incognito's address bar or open URLs from the share sheet. Supported search engines include Google, Bing, DuckDuckGo, Kagi, ChatGPT, and others — and you can add a custom engine. Incognito never reroutes your searches through its own servers."
			  }
			},
			{
			  "@type": "Question",
			  "name": "Can I keep my history and bookmarks private with a passcode?",
			  "acceptedAnswer": {
				"@type": "Answer",
				"text": "Yes. Incognito lets you lock your browsing history and bookmarks behind a passcode, so they stay private even if someone else picks up your phone."
			  }
			},
			{
			  "@type": "Question",
			  "name": "Does Incognito work with Apple Shortcuts?",
			  "acceptedAnswer": {
				"@type": "Answer",
				"text": "Yes. Incognito supports Apple Shortcuts, so you can automate private browsing workflows — for example, opening a specific URL in Incognito with a single tap or voice command."
			  }
			},
			{
			  "@type": "Question",
			  "name": "Can I open a page in Safari or another browser from Incognito?",
			  "acceptedAnswer": {
				"@type": "Answer",
				"text": "Yes. From within Incognito you can hand off any page to Safari, Chrome, Firefox, Opera, Brave, or DuckDuckGo with a single tap."
			  }
			},
			{
			  "@type": "Question",
			  "name": "Is Incognito really private? Does it send my data anywhere?",
			  "acceptedAnswer": {
				"@type": "Answer",
				"text": "Yes, it's genuinely private. Incognito contains no third-party trackers, no ads, and does not reroute or log your searches or browsing. Its paid-upfront business model means there is no financial incentive to monetize your data. It can also be excluded from iCloud Backups entirely."
			  }
			}
		  ]
		}

