  body
				
		div.container-xl
		
			header
				div.row.align-items-center
					div.col-sm-5
						img.xrounded-icon.mx-auto.me-sm-0.d-block.py-3 src='/incognito/icon-glass.png' alt='Incognito App Icon' style='max-width: 180px;'
						
					div.col-sm-7.text-sm-left
						h1.pb-2 Incognito
						h5 Private Browsing, Anywhere.
						p.mb-sm-2 Open a web browser from inside any app.<br/>Everything you do is kept private.
							
				div.row.align-items-center
					div.col-sm-5
					div.col-sm-7.text-sm-left
						a href='https://itunes.apple.com/app/id1490656387'
							img src='Download_on_the_App_Store_Badge_US-UK_RGB_blk_092917.svg' alt='Download on the App Store'
							
							
			section.themed
				div.row.align-items-end.text-center
					div.col-sm-4.mb-4
						h4.mb-3 Browse Anywhere
						img.img-fluid.rounded src='web1.png' srcset='web1.png 1x, web1@2x.png 2x' alt='Screenshot of Incognito browser popped-up inside another app.'
					div.col-sm-4.mb-4
						h4.mb-3 Lock Your History
						img.img-fluid.rounded src='web2.png' srcset='web2.png 1x, web2@2x.png 2x' alt='Screenshot of Incognit’s History screen, but the content is hidden and a buttom prompts you to enter a passcode to unlock it.'
					div.col-sm-4.mb-4
						h4.mb-3 Share Like a Pro
						img.img-fluid.rounded src='web3.png' srcset='web3.png 1x, web3@2x.png 2x' alt='Screenshot of Incognito’s custom actions, including clearing history, removing AMP links, translating a web page, and opening the current page in Safari, Firefox, Chrome, and more.'
						
			
			section
				div.row
					div.col-lg-9.mx-auto
						div.row
						
							- @bullets = [{ :icon => 'fa-face-disguise fa-duotone fa-stack-2x', 
									:text => 'Incognito helps you avoid the spying eyes of in‑app browsers¹.' },
								{ :icon => 'fa-arrow-up-from-square', 
									:text => 'Pop-up a secure browser inside any app, right from the share sheet.' },
								{ :icon => 'fa-magnifying-glass', 
									:text => 'Choose your search engine: Google, Bing, DuckDuckGo, etc.' },
								{ :icon => 'fa-rectangle-pro', 
									:text => 'Pro tools: translate, open in archive.is, automate with Shortcuts.' },
								{ :icon => 'fa-cookie-bite',
									:text => 'Reset cookie paywalls and block trackers.' },
								{ :icon => 'fa-lock', 
									:text => 'Passcode-lock your history and bookmarks.' },
								{ :icon => 'fa-up-right-and-down-left-from-center', 
									:text => 'Fullscreen browsing.' },
								{ :icon => 'fa-circle-check',
									:text => '100% private — no subscription, no ads, no sketchy search engines or embedded trackers.' }]
									
							- @bullets.each do | row |
  								div.col-sm-6
	  								div.row.g-0.align-items-baseline.mb-3
		  								div.col-auto.me-2
			  								span.fa-stack
				  								span.fa-solid.fa-circle.fa-stack-2x 
				  								span class=["fa-solid", "fa-stack-1x", row[:icon]]
		  								div.col
			  								p.my-0 = row[:text]
											  
							
							div.col-12.text-center.small.mt-5.mh-5
								p 
								| [1] <a href='https://www.pcmag.com/how-to/how-to-stop-facebook-from-spying-on-your-internet-activity'>Facebook and Instagram Are Spying on Your Internet Activity</a>, <br/><i>PCMag</i>, 3 Sept. 2025
			
			
