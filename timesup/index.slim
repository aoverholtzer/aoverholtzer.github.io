	javascript type="application/ld+json":
		{
		  "@context": "https://schema.org",
		  "@type": "FAQPage",
		  "mainEntity": [
			{
			  "@type": "Question",
			  "name": "What is Time’s Up!?",
			  "acceptedAnswer": {
				"@type": "Answer",
				"text": "Time’s Up! is a fun, visual countdown timer for iPhone, iPad, Mac, and Apple TV. Unlike plain timers, it counts down with colorful animations and photos — making it engaging for kids and adults alike. It supports iCloud sync, Guided Access for kid-friendly use, and AirPlay to show timers on a TV screen."
			  }
			},
			{
			  "@type": "Question",
			  "name": "Is Time’s Up! free?",
			  "acceptedAnswer": {
				"@type": "Answer",
				"text": "Yes, Time’s Up! is a free download. A simple one-time in-app purchase unlocks unlimited timers. There is no subscription, no ads, and no data collection."
			  }
			},
			{
			  "@type": "Question",
			  "name": "What does the one-time purchase unlock?",
			  "acceptedAnswer": {
				"@type": "Answer",
				"text": "The one-time purchase unlocks the ability to run an unlimited number of saved timers. The free version lets you try the app; the purchase removes that limit permanently with no recurring fee."
			  }
			},
			{
			  "@type": "Question",
			  "name": "What platforms does Time’s Up! support?",
			  "acceptedAnswer": {
				"@type": "Answer",
				"text": "Time’s Up! runs on iPhone, iPad (iOS/iPadOS), Mac (macOS), and Apple TV (tvOS). Timers sync across all your devices via iCloud."
			  }
			},
			{
			  "@type": "Question",
			  "name": "What are the timer styles in Time’s Up!?",
			  "acceptedAnswer": {
				"@type": "Answer",
				"text": "Time’s Up! offers 7 countdown styles: Clockface (a cute animated character), Reveal (a photo from your Camera Roll is gradually uncovered as time runs out), Pixelate (a photo becomes clearer as the timer approaches zero), Puzzle (a photo is broken into jigsaw pieces that fall into place as time progresses), Gradient (a color-changing style that draws your eye), plus two classic clock face styles. All styles can be customized with a color and alert sound."
			  }
			},
			{
			  "@type": "Question",
			  "name": "Can I use my own photos in a timer?",
			  "acceptedAnswer": {
				"@type": "Answer",
				"text": "Yes. The Reveal, Pixelate, and Puzzle styles can use any photo from your Camera Roll. Kids especially love watching a photo of their pet or favorite character slowly appear as the timer counts down."
			  }
			},
			{
			  "@type": "Question",
			  "name": "Is Time’s Up! good for kids?",
			  "acceptedAnswer": {
				"@type": "Answer",
				"text": "Yes — it was originally built for the developer's toddlers. Visual timers help kids understand that time is passing without requiring them to read numbers. Custom photo timers keep them engaged. And Guided Access lets you lock the app so kids can't switch away or change the timer."
			  }
			},
			{
			  "@type": "Question",
			  "name": "Is Time’s Up! good as a focus timer for folks with ADHD?",
			  "acceptedAnswer": {
				"@type": "Answer",
				"text": "Yes, this is a popular use case! Time’s Up! uses sounds and color changes to keep you engaged and aware. On Mac, Time’s Up! can float above other apps so it’s always visible."
			  }
			},
			{
			  "@type": "Question",
			  "name": "What is Guided Access and how does it work with Time’s Up!?",
			  "acceptedAnswer": {
				"@type": "Answer",
				"text": "Guided Access is an Apple iOS feature that locks the device to a single app. When you enable it with Time’s Up!, your child cannot leave the app, stop the timer, or use other apps until a parent triple-clicks the side button and enters a passcode. Enable it in Settings → Accessibility → Guided Access."
			  }
			},
			{
			  "@type": "Question",
			  "name": "Does Time’s Up! work on Apple TV?",
			  "acceptedAnswer": {
				"@type": "Answer",
				"text": "Yes. Time’s Up! has a native Apple TV app, and you can also AirPlay a timer from your iPhone or iPad to any TV that supports AirPlay Mirroring. A large-screen timer is great for exercise groups, classrooms, family activities, or anytime everyone in the room needs to see the countdown."
			  }
			},
			{
			  "@type": "Question",
			  "name": "Does Time’s Up! sync across my devices?",
			  "acceptedAnswer": {
				"@type": "Answer",
				"text": "Yes. Time’s Up! syncs your saved timers between iPhone, iPad, Mac, and Apple TV using iCloud, so the timers you create on one device are available everywhere."
			  }
			},
			{
			  "@type": "Question",
			  "name": "Does Time’s Up! have ads or collect data?",
			  "acceptedAnswer": {
				"@type": "Answer",
				"text": "No. Time’s Up! has no ads and no data trackers of any kind. The developer believes your data belongs to you, so nothing is collected. The app is supported by a one-time in-app purchase, not by advertising."
			  }
			},
			{
			  "@type": "Question",
			  "name": "Does Time’s Up! integrate with Focus mode?",
			  "acceptedAnswer": {
				"@type": "Answer",
				"text": "Yes. Time’s Up! integrates with Apple's Focus modes, so you can use timers as part of a focused work or study session."
			  }
			},
			{
			  "@type": "Question",
			  "name": "How is Time’s Up! different from the built-in iPhone timer?",
			  "acceptedAnswer": {
				"@type": "Answer",
				"text": "The built-in Clock timer is plain — white numbers on a black background. Time’s Up! replaces that with visual countdowns using color, animation, and photos. It also supports saving multiple named timers, iCloud sync across devices, Guided Access for kids, AirPlay to a TV, Focus integration, and Apple Shortcuts automation."
			  }
			},
			{
			  "@type": "Question",
			  "name": "Does Time’s Up! work with Apple Shortcuts?",
			  "acceptedAnswer": {
				"@type": "Answer",
				"text": "Yes. Time’s Up! supports Apple Shortcuts, so you can start timers via Siri or automate them in Shortcuts workflows."
			  }
			},
			{
			  "@type": "Question",
			  "name": "Is there a Mac app?",
			  "acceptedAnswer": {
				"@type": "Answer",
				"text": "Yes. Time’s Up! runs natively on macOS with a floating timer window you can keep above other apps. Timers sync from your iPhone and iPad via iCloud."
			  }
			}
		  ]
		}

