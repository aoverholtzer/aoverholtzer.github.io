		div.container-lg style='max-width: 1140px;'

			header
				div.row.align-items-center
					div.col-sm-5
						//div.phone.float-sm-end.mb-sm-0.mb-5
						div.embed-responsive.embed-responsive-9by16.float-sm-end.max333
							<video class="embed-responsive-item" autoplay muted playsinline preload="metadata" width="100%" onclick="playPauseRestart(this);">
							  <source src="video.mp4" type="video/mp4">
							  Your browser does not support the video tag.
							</video>
								
								//img.img-fluid src='web1.png' srcset='web1.png 1x, web1@2x.png 2x' alt='Fun visual timer counting down with a colorful photo reveal.'

					div.col-sm-7.text-sm-left
						img.rounded-icon.my-3 src='/timesup/icon.png' alt='Time’s Up! App Icon' style='max-width: 180px;'
						h1.pb-1 Time’s Up!
						p.mb-4 <strong>Fun visual timers</strong> that you (and your kids) will actually want&nbsp;to&nbsp;use.
						a href='https://itunes.apple.com/app/id1550456653'
							img src='Download_on_the_App_Store_Badge_US-UK_RGB_blk_092917.svg' alt='Download on the App Store'


			section.themed
				div.row.align-items-top.text-center
					div.col-sm-4.mb-3.mb-sm-0
						span.fa-stack
							span.fa-solid.fa-circle.fa-stack-2x
							span.fa-solid.fa-stack-1x.fa-child-reaching
						p Great for <strong>kids</strong>: Colors, photos, and animations keep them engaged.

					div.col-sm-4.mb-3.mb-sm-0
						span.fa-stack
							span.fa-solid.fa-circle.fa-stack-2x
							span.fa-solid.fa-stack-1x.fa-brain
						p.strong Great for <strong>focus</strong>: Track your time with a simple, floating timer.

					div.col-sm-4
						span.fa-stack
							span.fa-solid.fa-circle.fa-stack-2x
							span.fa-solid.fa-stack-1x.fa-people-group
						p.strong Great for <strong>groups</strong>: put a timer up on your TV for exercise, classrooms, or family activities.


			div.row.align-items-center.text-center.my-5
				div.col-sm-5.mx-auto
					div.phone.max333.float-sm-end.mb-sm-0.mb-5
						div
							img.img-fluid src='phone@1x.png' srcset='phone@1x.png 1x, phone@2x.png 2x' alt='Time’s Up! timer app running a colorful classic timer.'

				div.col-sm-7.text-start
					h2.mb-4 Beautiful, Visual Timers

					- @bullets = [{ :icon => 'fa-palette',
						  :text => 'Choose from 7 fun styles including Reveal, Pixelate, Puzzle, and Classic.' },
						{ :icon => 'fa-image',
						  :text => 'Customize with your own photos — perfect for little kids who love seeing photos of themselves!' },
						{ :icon => 'fa-lock',
						  :text => 'Enable Guided Access to kid-proof the app and disable app switching.' },
						  { :icon => 'fa-bell-on',
							:text => 'Notifications, widgets, and Live Activities help you monitor your timer.' },
						  { :icon => 'fa-volume',
							:text => 'Sounds! Play a chime each minute, countdown the last 10 seconds, and more.' },
						{ :icon => 'fa-tv',
						  :text => 'Put your timers on the big screen with AirPlay or Apple TV.' },
					  	{ :icon => 'fa-arrow-up-left-from-circle fa-flip-horizontal',
							:text => 'Pop out your timer into an always-visible floating window on Mac.' },
						{ :icon => 'fa-cloud',
						  :text => 'Syncs across all your devices.' },
						{ :icon => 'fa-layer fa-duotone',
						  :text => 'Schedule and automate timers with Shortcuts.' }]

					- @bullets.each do |row|
						div.row.g-0.align-items-baseline.mb-3
							div.col-auto.me-2
								span.fa-stack
									span.fa-solid.fa-circle.fa-stack-2x
									span class=["fa-solid", "fa-stack-1x", row[:icon]]
							div.col
								p.my-0 = row[:text]


			section.gray
				div.row.align-items-center
					div.col-12.text-center
						img.img-fluid src='web6.png' srcset='web6.png 1x, web6@2x.png 2x' alt='Time’s Up! on iPhone, iPad, Mac, and Apple TV.'
						p
							strong Time’s Up! is a free download for iPhone, iPad, Mac, and Apple TV.
						p After you’ve tried the app a few times, unlock it forever with a single, one-time purchase.
						p.small Looking for Volume Purchase Program (VPP) pricing? Download <a class='linky' href='https://apps.apple.com/us/app/times-up-timer-vpp/id6737355403'>Time’s Up! VPP</a> for education customers.



			footer.gray1.mb-xl-4
