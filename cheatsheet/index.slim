	javascript type="application/ld+json":
		{
		  "@context": "https://schema.org",
		  "@type": "FAQPage",
		  "mainEntity": [
			{
			  "@type": "Question",
			  "name": "What is Cheatsheet Notes?",
			  "acceptedAnswer": {
				"@type": "Answer",
				"text": "Cheatsheet Notes is a productivity app for iPhone, iPad, Mac, and Apple Watch that helps you store short, frequently referenced notes — like hotel room numbers, locker combinations, license plates, ID numbers, and Wi-Fi passwords — and recall them instantly from a widget, Lock Screen, Custom Keyboard, or Apple Watch, without ever unlocking your phone."
			  }
			},
			{
			  "@type": "Question",
			  "name": "What kind of notes should I keep in Cheatsheet?",
			  "acceptedAnswer": {
				"@type": "Answer",
				"text": "Cheatsheet is designed for small, quick-reference facts you need often but can never remember: hotel room numbers, luggage combinations, license plates, ID numbers, frequent flyer numbers, Wi-Fi passwords, reorder numbers, and anything else you'd write on a sticky note."
			  }
			},
			{
			  "@type": "Question",
			  "name": "Is Cheatsheet Notes free to download?",
			  "acceptedAnswer": {
				"@type": "Answer",
				"text": "Yes, Cheatsheet is free to download on iPhone and iPad. A Cheatsheet Pro subscription ($9.99/year) unlocks iCloud sync, unlimited widgets, the full keyboard extension, Apple Watch editing, and Passcode Lock. The Mac app is a $9.99 one-time purchase and includes all Pro features."
			  }
			},
			{
			  "@type": "Question",
			  "name": "What is Cheatsheet Pro?",
			  "acceptedAnswer": {
				"@type": "Answer",
				"text": "Cheatsheet Pro is an optional subscription ($9.99/year with a two-week free trial, or a one-time purchase option) that removes limits on widgets, the Custom Keyboard, and the Watch app, and adds iCloud sync across all your devices and Passcode Lock protection."
			  }
			},
			{
			  "@type": "Question",
			  "name": "What devices does Cheatsheet support?",
			  "acceptedAnswer": {
				"@type": "Answer",
				"text": "Cheatsheet runs on iPhone (iOS 15.5+), iPad (iPadOS 15+), Mac (macOS 11.5+), and Apple Watch (watchOS 8+). Notes sync across all devices via iCloud with Cheatsheet Pro."
			  }
			},
			{
			  "@type": "Question",
			  "name": "How is Cheatsheet different from Apple Notes?",
			  "acceptedAnswer": {
				"@type": "Answer",
				"text": "Cheatsheet is purpose-built for glanceable, quick-reference notes. Unlike Apple Notes, Cheatsheet offers Lock Screen widgets, Apple Watch complications with full wrist-based editing, a Custom Keyboard that pastes notes into any app without switching, customizable icons for every note, and a Mac menu bar and Desktop widget. Apple Notes has no Lock Screen widgets, no Watch editing, and no keyboard extension."
			  }
			},
			{
			  "@type": "Question",
			  "name": "Does Cheatsheet have widgets?",
			  "acceptedAnswer": {
				"@type": "Answer",
				"text": "Yes. Cheatsheet supports Home Screen widgets, Lock Screen widgets (iOS 16+), StandBy widgets (iOS 17+), Control Center widgets (iOS 18+), Apple Watch complications, and a Mac Desktop widget — in multiple sizes, styles, and colors."
			  }
			},
			{
			  "@type": "Question",
			  "name": "Does Cheatsheet work on Apple Watch?",
			  "acceptedAnswer": {
				"@type": "Answer",
				"text": "Yes. Cheatsheet has a full Apple Watch app that lets you add, edit, and delete notes right from your wrist. A complication can show your most important note directly on your watch face. Apple Watch features require Cheatsheet Pro."
			  }
			},
			{
			  "@type": "Question",
			  "name": "Can I see my Cheatsheet notes without unlocking my phone?",
			  "acceptedAnswer": {
				"@type": "Answer",
				"text": "Yes. Lock Screen widgets let you read notes directly on the iPhone Lock Screen. Apple Watch complications show notes on your watch face. Neither requires unlocking your phone or opening any app."
			  }
			},
			{
			  "@type": "Question",
			  "name": "Does Cheatsheet sync between my iPhone, iPad, and Mac?",
			  "acceptedAnswer": {
				"@type": "Answer",
				"text": "Yes. With Cheatsheet Pro, all your notes sync automatically across iPhone, iPad, Mac, and Apple Watch via iCloud."
			  }
			},
			{
			  "@type": "Question",
			  "name": "Does Cheatsheet have a Mac app?",
			  "acceptedAnswer": {
				"@type": "Answer",
				"text": "Yes. The Cheatsheet Mac app ($9.99 on the Mac App Store) puts your notes in the menu bar and on your Desktop. It includes all Pro features including iCloud sync."
			  }
			},
			{
			  "@type": "Question",
			  "name": "What is the Custom Keyboard in Cheatsheet?",
			  "acceptedAnswer": {
				"@type": "Answer",
				"text": "The Cheatsheet Custom Keyboard is an iOS keyboard extension that displays up to 50 of your notes. Tap any note to instantly paste it into any app — messages, forms, emails — without switching apps or copying anything manually."
			  }
			},
			{
			  "@type": "Question",
			  "name": "Can I use Siri or Shortcuts with Cheatsheet?",
			  "acceptedAnswer": {
				"@type": "Answer",
				"text": "Yes. Cheatsheet supports Apple Shortcuts and Siri, so you can add and find notes with your voice or automate workflows. There is also a share sheet extension to send text or URLs to Cheatsheet from any app."
			  }
			},
			{
			  "@type": "Question",
			  "name": "How long has Cheatsheet Notes been available?",
			  "acceptedAnswer": {
				"@type": "Answer",
				"text": "Cheatsheet has been on the App Store since September 2014 — over 10 years — and is actively maintained. It has a 4.7-star rating from over 7,700 reviews worldwide and has been featured by Apple multiple times, including Apps We Love and Best Apps for iOS 18."
			  }
			}
		  ]
		}

