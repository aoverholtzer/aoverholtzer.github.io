body
			
	div.container-md style='max-width: 768px;'
			
		header
			div.row.align-items-center
				div.col-sm-5
					img.rounded-icon.mx-auto.mr-sm-0.mt-sm-3.d-block src='icon.png' alt='App Icon' style='max-width: 232px;'
					
				div.col-lg-6.col-md-6.col-sm-6.text-sm-left.text-center
					h2.pb-2
						strong Cheatsheet Notes
						
					h6.mb-4 Write once, recall anywhere
					
					a href='https://itunes.apple.com/app/id914665829'
						img src='Download_on_the_App_Store_Badge_US-UK_RGB_blk_092917.svg' alt='Download on the iOS App Store'
					| &nbsp;
					a href='https://itunes.apple.com/app/id1468213484'
						img src='Download_on_the_Mac_App_Store_Badge_US-UK_RGB_blk_092917.svg' alt='Download on the Mac App Store'
						
						
		section
			div.row.align-items-center 
				//.px-xl-5.px-lg-4

				div.col-sm-8.order-12.order-sm-1
					- @bullets = [ { :icon => 'fa-pencil',
							:text => 'For the little things you never remember: put them in Cheatsheet.' }, 
						{ :icon => 'fa-icons', 
							:text => 'Choose from 200 icons to make your note easy to recognize.' },
						{ :icon => 'fa-note-sticky', 
							:text => 'Stick widgets everywhere: Home Screen, Lock Screen, Watch face, Desktop, and beyond.' },
						{ :icon => 'fa-keyboard', 
							:text => 'Paste into other apps with iOS custom keyboard.' },
						{ :icon => 'fa-robot', 
							:text => 'Supercharge your workflow with Shortcuts.' },
						{ :icon => 'fa-party-horn', 
							:text => 'Celebrating 10 years on the App Store. Thousands of 5-star reviews.' }]
							
			  		- @bullets.each do | row |
					  	div.row.no-gutters.align-items-baseline.mb-3
						  	div.col-auto.mr-2
							  	span.fa-stack
								  	span.fa-solid.fa-circle.fa-stack-2x 
								  	span class=["fa-solid", "fa-stack-1x", row[:icon]]
							div.col
							  	p.my-0 = row[:text]
								  
				div.col-sm-4.order-1.order-sm-12.mb-4.mb-sm-0
					img.img-fluid.mx-auto.d-block src='images/web-phone@1x.png' srcset='images/web-phone@1x.png 1x, images/web-phone@2x.png 2x' alt='Cheatsheet widgets on an iPhone Home Screen.'
					
		section.gray
			div.row.align-items-center.mr-sm-3.mr-0
				div.col-sm-4
					img.img-fluid.mx-auto.d-block src='images/web-watch@1x.png' srcset='images/web-watch@1x.png 1x, images/web-watch@2x.png 2x' alt='Cheatsheet on an Apple Watch.'
				div.col-sm-8.mt-3
					- @bullets = [ { :icon => 'fa-watch-smart', 
							:text => 'Full-featured Watch app with editing, widgets, and complications.' },
						{ :icon => 'fa-cloud', 
							:text => 'Sync notes to all your devices with iCloud.' },
						{ :icon => 'fa-folder-closed', 
							:text => 'Organize with folders.' }]
							
					- @bullets.each do | row |
						div.row.no-gutters.align-items-baseline.mb-3
							div.col-auto.mr-2.ml-2.ml-sm-0
								span.fa-stack
									span.fa-solid.fa-circle.fa-stack-2x 
									span class=["fa-solid", "fa-stack-1x", row[:icon]]
							div.col
								p.my-0 = row[:text]
								
								
		section
			div.row.align-items-center
				div.col-sm-6.order-12.order-sm-1
					- @bullets = [ { :icon => 'fa-computer-classic', 
							:text => 'Cheatsheet for Mac puts notes on your Desktop and menu bar.' },
						{ :icon => 'fa-font-case', 
							:text => 'Format with bold, italic, links, lists.' },
						{ :icon => 'fa-globe fa-regular', 
							:text => 'Localized in English, French, German, Italian, Japanese, Korean, Portuguese, Russian, Chinese, and Spanish.' }]
							
					- @bullets.each do | row |
						div.row.no-gutters.align-items-baseline.mb-3
							div.col-auto.mr-2.ml-2.ml-sm-0
								span.fa-stack
									span.fa-solid.fa-circle.fa-stack-2x 
									span class=["fa-solid", "fa-stack-1x", row[:icon]]
							div.col
								p.my-0 = row[:text]
				div.col-sm-6.order-1.order-sm-12.mb-4.mb-sm-0
					img.img-fluid.mx-auto.d-block src='images/web-mac@1x.png' srcset='images/web-mac@1x.png 1x, images/web-mac@2x.png 2x' alt='Cheatsheet on a Mac.'

		section.gray
			div.row.mt-3
				div.col-8.offset-2.align-items-center.text-center
					p Featured in <a href="https://techcrunch.com/2024/09/30/18-apps-that-add-useful-actions-to-the-ios-18-control-center/" rel="noopener">TechCrunch</a>, <a href="https://www.tapsmart.com/features/classics-cheatsheet/" rel="noopener">TapSmart</a>, <a href="https://9to5mac.com/2023/09/18/the-best-ios-17-apps-with-interactive-widgets-and-standby/" rel="noopener">9to5Mac</a>, <a href="https://gizmodo.com/11-apple-watch-apps-you-need-to-install-asap-1843780828" rel="noopener">Gizmodo</a>, <a href="https://www.macworld.com/article/231617/best-free-apple-watch-apps.html" rel="noopener">Macworld</a>, and <a href="https://www.slashgear.com/2122290/apps-you-should-be-using-apple-watch-2026/" rel="noopener">SlashGear</a>, and more.

						
		section
			div.row
				div.col.align-items-center
					picture
						//source srcset='images/banner@2x.jpg 1x' media='(max-width: 576px)'
						source srcset='images/banner@1x.jpg 1x, images/banner@2x.jpg 2x'
						img.rounded.img-fluid src='images/banner@1x.jpg' alt='Cheatsheet Notes logo'
		
		footer.mb-xl-4
			div.row.text-center.small
				div.col
				  p 
